import matplotlib.pyplot as plt
import numpy as np

from puck_dynamics.physics.trajectory import PuckState
from puck_dynamics.simulation.engine import simulate_trajectory
from puck_dynamics.distributions.velocity_distribution import sample_velocity


def sample_shot():

    zones = [
        ("slot", 53, 12.95, 2, 3),
        ("left_circle", 50, 7, 2, 2),
        ("right_circle", 50, 19, 2, 2),
        ("left_point", 42, 7, 3, 2),
        ("right_point", 42, 19, 3, 2),
    ]

    weights = np.array([0.4, 0.2, 0.2, 0.1, 0.1])
    weights /= weights.sum()

    zone = zones[np.random.choice(len(zones), p=weights)]

    name, cx, cy, sx, sy = zone

    x = np.random.normal(cx, sx)
    y = np.random.normal(cy, sy)

    return x, y, name


plt.figure(figsize=(10, 5))

for _ in range(20):

    x0, y0, zone = sample_shot()

    vel = sample_velocity(
        x0,
        y0,
        zone,
    )

    state = PuckState(
        x=x0,
        y=y0,
        z=0.2,
        vx=vel["vx"],
        vy=vel["vy"],
        vz=vel["vz"],
    )

    result = simulate_trajectory(state)

    plt.plot(
        result["x"],
        result["y"],
        alpha=0.7,
    )

plt.xlim(35, 61)
plt.ylim(0, 26)

plt.xlabel("x (m)")
plt.ylabel("y (m)")

plt.title("Simulated Offensive-Zone Puck Trajectories")

plt.grid(True)

plt.show()
